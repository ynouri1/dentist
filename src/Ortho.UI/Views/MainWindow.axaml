<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ortho.UI.ViewModels"
        xmlns:loc="using:Ortho.UI.Localization"
        x:Class="Ortho.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{x:Static loc:L.AppTitle}"
        Width="1200" Height="750">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Barre d'outils -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding SearchText}" PlaceholderText="{x:Static loc:L.SearchPlaceholder}" Width="320" />
                <Button Content="{x:Static loc:L.NewPatient}" Command="{Binding NewPatientCommand}" />
                <Button Content="{x:Static loc:L.BackupData}" Command="{Binding BackupCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentUserDisplay}" VerticalAlignment="Center" Opacity="0.7" />
                <Button Content="{x:Static loc:L.Lock}" Command="{Binding LockCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" Margin="12,0,12,0">

            <!-- Liste des patients -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedPatient}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FileNumber}" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Dossier patient -->
            <TabControl Grid.Column="1" Margin="16,0,0,0"
                        IsVisible="{Binding Form, Converter={x:Static ObjectConverters.IsNotNull}}">

                <TabItem Header="{x:Static loc:L.TabRecord}">
                    <ScrollViewer>
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <TextBlock Text="{Binding Form.Title}" FontSize="20" FontWeight="Bold" />

                            <TextBlock Text="{Binding Form.Error}"
                                       Foreground="Red" TextWrapping="Wrap"
                                       IsVisible="{Binding Form.Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:L.LabelLastName}" />
                                <TextBox  Grid.Row="1" Grid.Column="0" Text="{Binding Form.LastName}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static loc:L.LabelFirstName}" />
                                <TextBox  Grid.Row="1" Grid.Column="2" Text="{Binding Form.FirstName}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:L.LabelBirthDate}" Margin="0,8,0,0" />
                                <DatePicker Grid.Row="3" Grid.Column="0" SelectedDate="{Binding Form.BirthDate}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Static loc:L.LabelSex}" Margin="0,8,0,0" />
                                <ComboBox Grid.Row="3" Grid.Column="2" SelectedIndex="{Binding Form.SexIndex}" MinWidth="160">
                                    <ComboBoxItem Content="{x:Static loc:L.SexUnknown}" />
                                    <ComboBoxItem Content="{x:Static loc:L.SexMale}" />
                                    <ComboBoxItem Content="{x:Static loc:L.SexFemale}" />
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static loc:L.LabelPhone}" Margin="0,8,0,0" />
                                <TextBox  Grid.Row="5" Grid.Column="0" Text="{Binding Form.Phone}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{x:Static loc:L.LabelEmail}" Margin="0,8,0,0" />
                                <TextBox  Grid.Row="5" Grid.Column="2" Text="{Binding Form.Email}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Text="{x:Static loc:L.LabelAddress}" Margin="0,8,0,0" />
                                <TextBox  Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding Form.Address}" />

                                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Text="{x:Static loc:L.LabelNotes}" Margin="0,8,0,0" />
                                <TextBox  Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3"
                                          Text="{Binding Form.Notes}"
                                          AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap" />
                            </Grid>

                            <Button Content="{x:Static loc:L.Save}"
                                    Command="{Binding SaveCommand}"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{x:Static loc:L.TabConsultations}" IsEnabled="{Binding HasSavedPatient}">
                    <Grid RowDefinitions="Auto,*" Margin="0,8,0,0">
                        <Border Grid.Row="0" Padding="8" CornerRadius="4"
                                Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Static loc:L.NewConsultation}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <DatePicker SelectedDate="{Binding NewConsultationDate}" />
                                    <TextBox Text="{Binding NewConsultationReason}" PlaceholderText="{x:Static loc:L.ReasonPlaceholder}" Width="260" />
                                </StackPanel>
                                <TextBox Text="{Binding NewConsultationNotes}" PlaceholderText="{x:Static loc:L.ClinicalNotesPlaceholder}"
                                         AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" />
                                <Button Content="{x:Static loc:L.Add}" Command="{Binding AddConsultationCommand}"
                                        HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <ListBox Grid.Row="1" ItemsSource="{Binding Consultations}" Margin="0,8,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Reason}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" Opacity="0.8" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static loc:L.TabImaging}" IsEnabled="{Binding HasSavedPatient}">
                    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,*" Margin="0,8,0,0">
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Spacing="8">
                            <Button Content="{x:Static loc:L.ImportImages}" Click="OnImportImagesClick" />
                            <Button Content="{x:Static loc:L.OpenViewer}" Click="OnOpenViewerClick"
                                    IsEnabled="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <Button Content="{x:Static loc:L.Cephalometry}" Click="OnCephalometryClick"
                                    IsEnabled="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <Button Content="{x:Static loc:L.Superposition}" Click="OnSuperpositionClick" />
                            <Button Content="{x:Static loc:L.DeleteImage}" Click="OnDeleteImageClick"
                                    IsEnabled="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <TextBlock Text="{Binding SelectedImageCalibration}"
                                       VerticalAlignment="Center" Opacity="0.8" />
                        </StackPanel>

                        <ListBox Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"
                                 ItemsSource="{Binding Images}"
                                 SelectedItem="{Binding SelectedImage}"
                                 DoubleTapped="OnOpenViewerClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Modality}" FontSize="12" Opacity="0.6" />
                                            <TextBlock Text="{Binding Width}" FontSize="12" Opacity="0.6" />
                                            <TextBlock Text="×" FontSize="12" Opacity="0.6" />
                                            <TextBlock Text="{Binding Height}" FontSize="12" Opacity="0.6" />
                                            <TextBlock Text="{Binding ImportedAtUtc, StringFormat={}{0:dd/MM/yyyy}}"
                                                       FontSize="12" Opacity="0.6" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" RowDefinitions="*,Auto">
                            <Border Grid.Row="0" CornerRadius="4"
                                    Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                                <Image Source="{Binding ImagePreview}" Stretch="Uniform" Margin="8" />
                            </Border>

                            <Border Grid.Row="1" Padding="8" Margin="0,8,0,0" CornerRadius="4"
                                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                                    IsVisible="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{x:Static loc:L.CalibrationPanelTitle}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBox Text="{Binding CalibrationKnownMm}"
                                                 PlaceholderText="{x:Static loc:L.CalibrationKnownMm}" Width="170" />
                                        <TextBox Text="{Binding CalibrationMeasuredPx}"
                                                 PlaceholderText="{x:Static loc:L.CalibrationMeasuredPx}" Width="190" />
                                        <Button Content="{x:Static loc:L.Calibrate}" Command="{Binding CalibrateCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static loc:L.TabDocuments}" IsEnabled="{Binding HasSavedPatient}">
                    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,*" Margin="0,8,0,0">
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Spacing="8">
                            <ComboBox SelectedIndex="{Binding ImportCategoryIndex}" MinWidth="180">
                                <ComboBoxItem Content="{x:Static loc:L.CategoryDocument}" />
                                <ComboBoxItem Content="{x:Static loc:L.CategoryIntraOral}" />
                                <ComboBoxItem Content="{x:Static loc:L.CategoryExtraOral}" />
                                <ComboBoxItem Content="{x:Static loc:L.CategoryRadiography}" />
                                <ComboBoxItem Content="{x:Static loc:L.CategoryExam}" />
                            </ComboBox>
                            <Button Content="{x:Static loc:L.ImportFiles}" Click="OnImportClick" />
                            <Button Content="{x:Static loc:L.DeleteDocument}" Click="OnDeleteDocumentClick"
                                    IsEnabled="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>

                        <ListBox Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"
                                 ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Category}" FontSize="12" Opacity="0.6" />
                                            <TextBlock Text="{Binding ImportedAtUtc, StringFormat={}{0:dd/MM/yyyy}}"
                                                       FontSize="12" Opacity="0.6" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" CornerRadius="4"
                                Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                            <Image Source="{Binding Preview}" Stretch="Uniform" Margin="8" />
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Barre de statut -->
        <Border Grid.Row="2" Padding="12,6" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" />
        </Border>
    </Grid>
</Window>
