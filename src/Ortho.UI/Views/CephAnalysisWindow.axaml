<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ortho.UI.ViewModels"
        xmlns:controls="using:Ortho.UI.Controls"
        xmlns:loc="using:Ortho.UI.Localization"
        x:Class="Ortho.UI.Views.CephAnalysisWindow"
        x:DataType="vm:CephAnalysisViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        Width="1350" Height="850">

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,380">

        <!-- Barre d'outils -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" Spacing="8" Margin="8">
            <TextBlock Text="{x:Static loc:L.TemplateLabel}" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate}"
                      MinWidth="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="{x:Static loc:L.UndoPoint}" Command="{Binding UndoCommand}" />
            <Button Content="{x:Static loc:L.RedoPoint}" Command="{Binding RedoCommand}" />
            <Button Content="{x:Static loc:L.ReportPdf}" Click="OnReportClick" />

            <Separator Width="12" />
            <TextBlock Text="{x:Static loc:L.BrightnessLabel}" VerticalAlignment="Center" />
            <Slider x:Name="BrightnessSlider" Minimum="-1" Maximum="1" Value="0" Width="110"
                    ValueChanged="OnBrightnessChanged" />
            <TextBlock Text="{x:Static loc:L.ContrastLabel}" VerticalAlignment="Center" />
            <Slider x:Name="ContrastSlider" Minimum="-1" Maximum="1" Value="0" Width="110"
                    ValueChanged="OnContrastChanged" />
        </StackPanel>

        <controls:CephCanvasControl x:Name="Canvas" Grid.Row="1" Grid.Column="0" />

        <!-- Panneau latéral : points + mesures -->
        <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,*,Auto,*" Margin="8,0,8,0">
            <TextBlock Grid.Row="0" Text="{x:Static loc:L.LandmarksHeader}" FontWeight="Bold" Margin="0,0,0,4" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Landmarks}"
                     SelectedItem="{Binding CurrentLandmark}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="✓" Foreground="MediumSeaGreen" IsVisible="{Binding IsPlaced}" />
                            <TextBlock Text="○" Opacity="0.5" IsVisible="{Binding !IsPlaced}" />
                            <TextBlock Text="{Binding Display}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Text="{x:Static loc:L.ResultsHeader}" FontWeight="Bold" Margin="0,8,0,4" />
            <ScrollViewer Grid.Row="3">
                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="10,*,Auto,Auto" Margin="0,2">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="12" />
                                    <TextBlock Text="{Binding Norm}" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Value}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="8,0" />
                                <TextBlock Grid.Column="3" Text="{Binding DeviationText}" FontSize="11"
                                           Opacity="0.7" VerticalAlignment="Center" MinWidth="46" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Barre de statut -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" />
        </Border>
    </Grid>
</Window>
