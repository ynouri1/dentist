<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ortho.UI.ViewModels"
        xmlns:loc="using:Ortho.UI.Localization"
        x:Class="Ortho.UI.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{x:Static loc:L.LoginWindowTitle}"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <StackPanel Margin="32" Spacing="10">
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" />

        <TextBlock Text="{Binding Error}"
                   Foreground="Red" TextWrapping="Wrap"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <TextBlock Text="{x:Static loc:L.LabelUsername}" />
        <TextBox Text="{Binding Username}" IsEnabled="{Binding !IsUnlock}" />

        <StackPanel Spacing="10" IsVisible="{Binding IsFirstRun}">
            <TextBlock Text="{x:Static loc:L.LabelDisplayName}" />
            <TextBox Text="{Binding DisplayName}" PlaceholderText="{x:Static loc:L.DisplayNamePlaceholder}" />
            <TextBlock Text="{x:Static loc:L.LabelRole}" />
            <ComboBox SelectedIndex="{Binding RoleIndex}" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="{x:Static loc:L.RolePraticien}" />
                <ComboBoxItem Content="{x:Static loc:L.RoleAssistante}" />
            </ComboBox>
        </StackPanel>

        <TextBlock Text="{x:Static loc:L.LabelPassword}" />
        <TextBox Text="{Binding Password}" PasswordChar="•" />

        <StackPanel Spacing="10" IsVisible="{Binding IsFirstRun}">
            <TextBlock Text="{x:Static loc:L.LabelPasswordConfirmation}" />
            <TextBox Text="{Binding PasswordConfirmation}" PasswordChar="•" />
        </StackPanel>

        <Button Content="{Binding SubmitLabel}"
                Command="{Binding SubmitCommand}"
                IsDefault="True"
                IsEnabled="{Binding !Busy}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,12,0,0" />
    </StackPanel>
</Window>
